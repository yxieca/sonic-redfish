#!/usr/bin/make -f
# -*- makefile -*-

# Uncomment this to turn on verbose mode.
#export DH_VERBOSE=1

export DEB_BUILD_MAINT_OPTIONS = hardening=+all
export DEB_CFLAGS_MAINT_APPEND  = -Wall -Wextra
export DEB_CXXFLAGS_MAINT_APPEND  = -Wall -Wextra

%:
	dh $@ --buildsystem=meson

override_dh_auto_configure:
	dh_auto_configure -- --wrap-mode=default

override_dh_auto_install:
	# Force install into debian/tmp so debian/sonic-dbus-bridge.install
	# (allow-list) and debian/not-installed can filter out sdbusplus
	# headers / pkgconfig / static lib dropped by the meson subproject.
	dh_auto_install --destdir=debian/tmp
	# Create state directory in staging so the allow-list picks it up
	install -d debian/tmp/var/lib/sonic-dbus-bridge

override_dh_installsystemd:
	dh_installsystemd --name=sonic-dbus-bridge --no-start

override_dh_makeshlibs:
	# sdbusplus is linked statically; do not emit shlibs for it
	dh_makeshlibs -Xlibsdbusplus

override_dh_shlibdeps:
	dh_shlibdeps --dpkg-shlibdeps-params=--ignore-missing-info

