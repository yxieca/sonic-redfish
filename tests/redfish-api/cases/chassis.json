[
  {
    "name": "test_collection_returns_200",
    "description": "Validates Collection returns 200",
    "method": "GET",
    "endpoint": "/redfish/v1/Chassis/",
    "expected_status": 200
  },
  {
    "name": "test_collection_has_members",
    "description": "Validates Collection has members",
    "method": "GET",
    "endpoint": "/redfish/v1/Chassis/",
    "expected_status": 200,
    "validators": [
      {
        "type": "length_gte",
        "path": "Members",
        "value": 1
      }
    ]
  },
  {
    "name": "test_odata_type",
    "description": "Validates Odata type",
    "method": "GET",
    "endpoint": "/redfish/v1/Chassis/",
    "expected_status": 200,
    "expected_response": {
      "@odata.type": "#ChassisCollection.ChassisCollection"
    }
  },
  {
    "name": "test_chassis_returns_200",
    "description": "Validates Chassis returns 200",
    "method": "GET",
    "endpoint": "{{STATE.CHASSIS_URI}}",
    "expected_status": 200,
    "prerequisite_calls": [
      {
        "endpoint": "/redfish/v1/Chassis/",
        "extract": {
          "CHASSIS_URI": "Members[0].@odata.id"
        }
      }
    ]
  },
